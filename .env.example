# ENVIRONMENT=dev
# HOST=0.0.0.0
# PORT=9000

# Shared secret the backend sends in the `X-API-Key` header.
# If unset, auth is disabled (dev only).
RETRIEVAL_API_KEY=change-me

# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_BATCH_SIZE=30

# CHUNK_SIZE=800
# CHUNK_OVERLAP=200
# WINDOW_SIZE=1500

# Leave QDRANT_URL unset to use embedded on-disk Qdrant at QDRANT_PATH.
QDRANT_URL=
QDRANT_API_KEY= 

# Hugging Face Token ( optional )
# HF_TOKEN=